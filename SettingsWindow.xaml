<!--
File path: SettingsWindow.xaml
What it does: Defines the settings dialog for startup and wallpaper folder selection.
Why it exists: Gives first-run setup and later settings changes a simple UI.
RELATED FILES: SettingsWindow.xaml.cs, Services/AppSettingsService.cs, Services/StartupService.cs, App.xaml.cs
-->
<Window x:Class="WallpaperQuick.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WallpaperQuick Settings"
        Width="520"
        Height="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{StaticResource AppTextBrush}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="2" CornerRadius="10" Padding="18" Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="44" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,16">
                <TextBlock Text="Settings"
                           FontFamily="Consolas"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <Button Content="X"
                        HorizontalAlignment="Right"
                        Width="28"
                        Height="28"
                        Click="Close_Click"
                        Background="{StaticResource AppPanelBrush}"
                        Foreground="{StaticResource AppTextBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        FontFamily="Consolas" />
            </Grid>

            <Border Grid.Row="1" BorderBrush="#282B3A" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10" Background="{StaticResource AppPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="88" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Wallpaper folder"
                               Grid.ColumnSpan="2"
                               FontFamily="Consolas"
                               FontSize="13"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="WallpaperFolderTextBox"
                             Grid.Row="1"
                             Margin="0,0,8,0"
                             Background="{StaticResource AppInputBrush}"
                             Foreground="{StaticResource AppTextBrush}"
                             BorderBrush="{StaticResource AppBorderBrush}"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="8,0"
                             VerticalContentAlignment="Center" />
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Content="Browse"
                            Click="Browse_Click"
                            Background="{StaticResource AppInputBrush}"
                            Foreground="{StaticResource AppTextBrush}"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            FontFamily="Consolas" />
                </Grid>
            </Border>

            <Border Grid.Row="2" BorderBrush="#282B3A" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10" Background="{StaticResource AppPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Picker shortcut"
                               FontFamily="Consolas"
                               FontSize="13"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="HotKeyTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             PreviewKeyDown="HotKeyTextBox_PreviewKeyDown"
                             Background="{StaticResource AppInputBrush}"
                             Foreground="{StaticResource AppTextBrush}"
                             BorderBrush="{StaticResource AppBorderBrush}"
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="8,0"
                             VerticalContentAlignment="Center" />
                </Grid>
            </Border>

            <CheckBox x:Name="StartWithWindowsCheckBox"
                      Grid.Row="3"
                      Content="Start WallpaperQuick when Windows starts"
                      Foreground="{StaticResource AppTextBrush}"
                      FontFamily="Consolas"
                      FontSize="13"
                      Margin="0,0,0,12" />

            <DockPanel Grid.Row="5" LastChildFill="False">
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           FontFamily="Consolas"
                           TextTrimming="CharacterEllipsis" />
                <Button Content="Save"
                        DockPanel.Dock="Right"
                        Width="88"
                        Click="Save_Click"
                        Background="#363A4B"
                        Foreground="{StaticResource AppTextBrush}"
                        BorderBrush="#4A4F64"
                        FontFamily="Consolas"
                        FontSize="13" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
