<!--
File path: App.xaml
What it does: Declares the WPF application entry point and shared dark UI resources.
Why it exists: Keeps shared colors and controls consistent across app windows.
RELATED FILES: App.xaml.cs, MainWindow.xaml, SettingsWindow.xaml, WallpaperQuick.csproj
-->
<Application x:Class="WallpaperQuick.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0D0E18" />
        <SolidColorBrush x:Key="AppPanelBrush" Color="#121321" />
        <SolidColorBrush x:Key="AppInputBrush" Color="#151625" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#3F4356" />
        <SolidColorBrush x:Key="AppTextBrush" Color="#D5D7E2" />
        <SolidColorBrush x:Key="AppMutedTextBrush" Color="#6F7282" />
        <SolidColorBrush x:Key="AppSelectedBrush" Color="#44485D" />
        <SolidColorBrush x:Key="AppHoverBrush" Color="#252838" />
        <SolidColorBrush x:Key="AppScrollbarTrackBrush" Color="#11121D" />
        <SolidColorBrush x:Key="AppScrollbarThumbBrush" Color="#3E4254" />
        <SolidColorBrush x:Key="AppScrollbarThumbHoverBrush" Color="#4D5267" />

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="7" />
            <Setter Property="Background" Value="{StaticResource AppScrollbarTrackBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder"
                                                        Background="{StaticResource AppScrollbarThumbBrush}"
                                                        CornerRadius="3" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AppScrollbarThumbHoverBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
