<!--
File path: MainWindow.xaml
What it does: Defines the wallpaper picker window shown by the hotkey.
Why it exists: Gives the user a fast searchable list of wallpapers with thumbnails.
RELATED FILES: MainWindow.xaml.cs, Models/WallpaperItem.cs, Services/WallpaperService.cs, App.xaml.cs
-->
<Window x:Class="WallpaperQuick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WallpaperQuick"
        Width="560"
        Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{StaticResource AppTextBrush}"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Border x:Name="PickerRoot"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="2"
            CornerRadius="10"
            Padding="14"
            Background="{StaticResource AppBackgroundBrush}"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#4A4F64" BorderThickness="2" CornerRadius="7" Background="{StaticResource AppInputBrush}">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="21" Height="21" VerticalAlignment="Center">
                        <Grid Width="24" Height="24">
                            <Border BorderBrush="{StaticResource AppTextBrush}" BorderThickness="2.3" CornerRadius="1.8" />
                            <Ellipse Width="3.7" Height="3.7" Fill="{StaticResource AppTextBrush}" Margin="5,5,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <Path Data="M4,18 L9,12 L13,15 L16,10 L21,18 Z" Fill="{StaticResource AppTextBrush}" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Grid.Column="1"
                               Text="&gt;"
                               FontFamily="Consolas"
                               FontSize="22"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AppTextBrush}" />
                    <TextBox x:Name="SearchBox"
                             Grid.Column="2"
                             TextChanged="SearchBox_TextChanged"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource AppTextBrush}"
                             CaretBrush="{StaticResource AppTextBrush}"
                             FontFamily="Consolas"
                             FontSize="22"
                             VerticalContentAlignment="Center" />
                    <TextBlock x:Name="Placeholder"
                               Grid.Column="2"
                               Text="Type to filter"
                               FontFamily="Consolas"
                               FontSize="22"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ListBox x:Name="WallpaperList"
                     Grid.Row="1"
                     Margin="0,12,0,0"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource AppTextBrush}"
                     SelectionChanged="WallpaperList_SelectionChanged"
                     MouseDoubleClick="WallpaperList_MouseDoubleClick"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Height" Value="44" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Row" Background="{TemplateBinding Background}" CornerRadius="7">
                                        <ContentPresenter Margin="0,0,0,0" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Row" Property="Background" Value="{StaticResource AppSelectedBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Row" Property="Background" Value="{StaticResource AppHoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <Image Width="42"
                                   Height="27"
                                   Source="{Binding Thumbnail}"
                                   Stretch="UniformToFill"
                                   Margin="4,0,10,0" />
                            <TextBlock Text="{Binding Name}"
                                       FontFamily="Consolas"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
